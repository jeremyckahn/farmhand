{
  "globals": {
    "vitest": true
  },
  "extends": ["react-app"],
  "rules": {
    "import/order": [
      "error",
      { "newlines-between": "always-and-inside-groups" }
    ],
    "import/extensions": ["error", "always"],
    "react/react-in-jsx-scope": ["off"],
    "no-shadow": ["error"],
    "@typescript-eslint/no-unused-vars": "off"
  }
}
